# Cloudflare Pages 安全与缓存配置

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: accelerometer=(), ambient-light-sensor=(), autoplay=(), browsing-topics=(), camera=(), clipboard-read=(), clipboard-write=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.coingecko.com https://api.llama.fi; frame-src 'self' https://www.youtube.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests

# HTML 文件不缓存，确保每次获取最新版本
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/indicators/*
  Cache-Control: no-cache, no-store, must-revalidate

/tev/*
  Cache-Control: no-cache, no-store, must-revalidate

# JSON 数据文件短缓存（5分钟）
/data/*.json
  Cache-Control: public, max-age=300

/indicators/data/*.json
  Cache-Control: public, max-age=300

# 静态资源长缓存（1天）
/*.css
  Cache-Control: public, max-age=86400

/*.js
  Cache-Control: public, max-age=86400

/images/*
  Cache-Control: public, max-age=86400
